// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider               = "prisma-client"
  output                 = "../prisma/generated/prisma"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "cjs"
  runtime                = "nodejs"
  previewFeatures        = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Provincia {
  id         Int         @id @default(autoincrement())
  nombre     String      @unique
  municipios Municipio[]
}

model Municipio {
  id          Int       @id @default(autoincrement())
  nombre      String
  provincia   Provincia @relation(fields: [provinciaId], references: [id])
  provinciaId Int
  parcelas    Parcela[]
}

model Usuario {
  id       Int       @id @default(autoincrement())
  nombre   String
  email    String    @unique
  password String
  parcelas Parcela[]
}

model Parcela {
  id          Int                                    @id @default(autoincrement())
  municipio   Municipio                              @relation(fields: [municipioId], references: [id])
  geom        Unsupported("geometry(Polygon, 4326)")
  usuario     Usuario                                @relation(fields: [usuarioId], references: [id])
  recintos    Recinto[]
  usuarioId   Int
  municipioId Int

  @@index([geom], type: Gist)
}

model Recinto {
  id           Int                                    @id @default(autoincrement())
  cultivo      Cultivo                                @relation(fields: [cultivoId], references: [id])
  cultivoId    Int
  fechaSiembra DateTime
  fechaCosecha DateTime?
  geom         Unsupported("geometry(Polygon, 4326)")
  parcela      Parcela                                @relation(fields: [parcelaId], references: [id])
  parcelaId    Int

  @@index([geom], type: Gist)
}

model Cultivo {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique
  recintos Recinto[]
}

model Movie {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  embedding   Unsupported("vector")
}
